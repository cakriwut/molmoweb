# Copy to .env and fill in (or export in your shell).

# Required path to task definitions JSON (unless you always pass --config).
# ANNOTATION_CONFIG=configs/example_tasks.json

# HTTP port for the annotation app (default 5001).
# ANNOTATION_PORT=5001

# Directory where session uploads are stored (default: ./uploads next to browser_app.py).
# ANNOTATION_DATA_DIR=/var/annotation-data

# Set to "development" to enable auto-reload while editing browser_app.py.
# ENV=production
